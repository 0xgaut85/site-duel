# ─────────────────────────────────────────────────────────────────────
# Public site links
NEXT_PUBLIC_GITHUB_URL=https://github.com/0xgaut85/site-duel

# Resend — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="Duel Agents <hello@duelagents.com>"
RESEND_NOTIFY_EMAIL=

# Upstash Redis — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Railway Postgres — https://railway.app
# Use the "Postgres Connection URL" from the Railway service variables tab.
DATABASE_URL=

# Better-Auth — https://www.better-auth.com
# `BETTER_AUTH_SECRET` is a random 32+ byte string.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Admin allow-list — comma-separated user emails. These accounts see
# the /admin pages (waitlist invites, per-account quotas).
DUEL_ADMIN_EMAILS=

# Real model provider keys (server-side; never shipped to clients).
# These are the ONLY two providers actually called. All other models
# in the catalog are display-only.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Stripe — https://dashboard.stripe.com
# Create Products/Prices for indie ($19), pro ($49), team ($199).
# Enable Stablecoin (USDC) in Payment methods if desired.
# Webhook endpoint: https://your-domain/api/webhooks/stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_INDIE=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# MoonPay Commerce — legacy placeholder (Stripe used for billing)
MOONPAY_API_KEY=
MOONPAY_WEBHOOK_SECRET=
MOONPAY_API_BASE_URL=https://api.moonpay.com
