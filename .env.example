# ─────────────────────────────────────────────────────────────────────
# Release flag — when "true", the /login + /dashboard + /api/auth/*
# routes are live and the dashboard is publicly reachable. When
# anything else (or unset), those routes 404 and the site behaves like
# the marketing-only build. Default OFF so a deploy without explicit
# opt-in stays invisible.
NEXT_PUBLIC_PRODUCT_LIVE=false

# Resend — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL="Duel Agents <hello@duel-agents.com>"
RESEND_NOTIFY_EMAIL=

# Upstash Redis — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Railway Postgres — https://railway.app
# Use the "Postgres Connection URL" from the Railway service variables tab.
DATABASE_URL=

# Better-Auth — https://www.better-auth.com
# `BETTER_AUTH_SECRET` is a random 32+ byte string.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Admin allow-list — comma-separated user emails. These accounts see
# the /admin pages (waitlist invites, per-account quotas).
DUEL_ADMIN_EMAILS=

# Real model provider keys (server-side; never shipped to clients).
# These are the ONLY two providers actually called. All other models
# in the catalog are display-only.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MoonPay Commerce — https://www.moonpay.com/business/commerce
# Used for subscription billing. Webhook secret is for signing
# verification on `/api/webhooks/moonpay`.
MOONPAY_API_KEY=
MOONPAY_WEBHOOK_SECRET=
MOONPAY_API_BASE_URL=https://api.moonpay.com
